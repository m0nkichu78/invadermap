# Mapbox GL JS — public token for map rendering
# Get it from: https://account.mapbox.com/access-tokens/
# Restrict to your domain in production to prevent abuse
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase project URL — public, safe to expose
# Get it from: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — public, safe to expose (RLS enforced)
# Get it from: Supabase Dashboard → Settings → API → anon (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SECRET, never prefix with NEXT_PUBLIC_
# Only used in server-side scripts (scripts/scrape-photos.ts, scripts/seed-supabase.ts)
# Get it from: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
